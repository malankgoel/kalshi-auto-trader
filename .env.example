# Kalshi credentials (required only for live or demo order submission)
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=/absolute/path/to/kalshi_private_key.pem

# Shared Kalshi API behavior
KALSHI_HTTP_TIMEOUT=20
KALSHI_HTTP_RETRIES=4
KALSHI_MARKET_PAGE_LIMIT=200

# Safe defaults for local dry runs
KALSHI_ORDER_TYPE=market
EDGE_THRESHOLD=0.10
KELLY_FRACTION=0.50
MAX_STAKE_FRACTION=0.25
BANKROLL=50
MAX_CONTRACTS_PER_ORDER=500
MAX_ORDER_COST=25
MAX_TOTAL_COST=100
KALSHI_LIMIT_BUFFER_CENTS=2
KALSHI_MARKET_SLIPPAGE_CENTS=3
